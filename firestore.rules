rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções Auxiliares
    function isAuthenticated() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && (getRole() == 'adm_l1' || getRole() == 'adm_l2');
    }

    // Configurações Globais (Permissões por Cargo)
    match /config/permissions {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Coleção de Cargos (Nova)
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Coleção de Usuários
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      // O próprio usuário pode ler seus dados
      allow read: if isAuthenticated() && request.auth.uid == userId;
    }

    // Módulo Notas (Meu Espaço)
    match /users/{userId}/notes/{noteId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Quadro de Avisos (Avisos Institucionais)
    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Módulo Empréstimo
    match /notebooks/{notebookId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getRole() == 'ti' || isAdmin());
    }

    // Módulo Ensalamento
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /calendarEntries/{entryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    function isRH() {
      return isAuthenticated() && (getRole() == 'rh' || isAdmin());
    }

    // Módulo RH (Carga Horária)
    match /funcionarios_rh/{docId} {
      allow read, write: if isRH();
    }
    match /registros_carga_horaria/{docId} {
      allow read, write: if isRH();
    }
    match /eventos_rh/{docId} {
      allow read, write: if isRH();
    }

    // Bloqueio Global - Medida de Segurança Máxima
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}

