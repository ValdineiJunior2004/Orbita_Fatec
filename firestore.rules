rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =====================================================================
    // ÓRBITA FATEC - RESTRICTED SERVER-SIDE ONLY ARCHITECTURE
    // =====================================================================
    // O sistema foi completamente migrado para uma API REST em Node.js.
    // Todas as operações de leitura e gravação acontecem no Backend 
    // usando o Firebase Admin SDK (que ignora estas regras por ser root).
    //
    // Portanto, QUALQUER tentativa de acesso direto pelo lado do cliente
    // (navegador, postman, etc) está PROIBIDA, garantindo segurança absoluta.
    // =====================================================================

    match /{document=**} {
      allow read, write: if false; 
    }
    
  }
}
